<% @page_title = "注文一覧" %>
<h1><%= @page_title %></h1>
<% if @orders.present? %>
  <table class = "attr">
    <thead>
      <tr>
        <th>注文番号</th>
        <th>合計金額</th>
        <th>受け渡し予定時間</th>
        <th>作成状況</th>
        <th>受け渡し状況</th>
        <th>削除項目</th>
      </tr>
    </thead>
    <% @orders.each do |order|%>
      <tbody>
        <tr>
          <td><%= menu_link_to order.id, account_order_path(order) %></td>
          <td><%= order.amount %></td>
          <td><%= order.reserve_time %></td>
          <td><%= order.created %></td>
          <td><%= order.reserved %></td>
          <% if order.created == false %>
            <td><%= link_to "削除", account_order_path(order) , method: :delete,
            data: { confirm: "本当に削除しますか?" } %></td>
          <% end %>
        </tr>
      </tbody>
    <% end %>
  </table>
<% else %>
  <p>注文が存在しません</p>
<% end %>

<p><%= menu_link_to "アカウント詳細へ戻る", :account %></p>