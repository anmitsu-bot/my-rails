<% @page_title = "注文一覧" %>
<h1><%= @page_title %></h1>
<% if @orders.present? %>
  <table class = "attr">
    <thead>
      <tr>
        <th>注文番号</th>
        <th>合計金額</th>
        <th>受け渡し予定時間</th>
        <th>作成開始</th>
        <th>作成状況</th>
        <th>受け渡し状況</th>
      </tr>
    </thead>
    <% @orders.each do |order|%>
      <tbody>
        <tr>
          <td><%= menu_link_to order.id, account_order_details_path(order_id: order.id) %></td>
          <td><%= order.amount %></td>
          <td><%= order.reserve_time %></td>
          <td><%= order.create_start %></td>
          <td><%= order.created %></td>
          <td><%= order.reserved %></td>
        </tr>
      </tbody>
    <% end %>
  </table>
<% else %>
  <p>注文が存在しません</p>
<% end %>

<p><%= menu_link_to "アカウント詳細へ戻る", :account %></p>