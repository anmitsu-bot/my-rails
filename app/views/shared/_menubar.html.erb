<nav class="menubar">
  <ul>
    <%= menu_link_to "TOP", :root %>
    <%= menu_link_to "商品一覧", :items %>
    <% if !current_member%>
      <%= menu_link_to "ログイン", login_path %>
      <%= menu_link_to "新規登録", new_account_path %>
    <% else %>
      <%= menu_link_to "マイページ", :account %>
      <%= menu_link_to "カート", :cart %>
      <% if current_member.role == 3 %>
        <%= menu_link_to "管理TOP", :admin_root %>
      <% end %>
      <% if current_member.role == 2 %>
        <%= menu_link_to "店員TOP", :staff_root %>
      <% end %>
    <% end %>
  </ul>
</nav>
