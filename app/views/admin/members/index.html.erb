<% @page_title = "アカウント一覧" %>
<h1><%= @page_title %></h1>

<div class="toolbar"><%= link_to "アカウントの新規作成", :new_admin_member %></div>

<% if @member %>
  <table class = "attr" >
    <thead>
      <tr>
        <th>会員番号</th>
        <th>名前</th>
        <th>権限</th>
        <th>編集</th>
      </tr>
    </thead>
    <tbody>
      <% @member.each do |member| %>
      <tr>
        <td><%= menu_link_to member.id, [:admin, member] %></td>
        <td><%= menu_link_to member.name,[:admin, member]   %></td>
        <td><%= member.role %></td>
        <td>
          <%= link_to "編集", [:edit, :admin, member] %> |
            <%= link_to "削除", [:admin, member], method: :delete,
            data: { confirm: "本当に削除しますか?" } %>
        </td>
      </tr>
      <% end %>
    </tbody>
  </table>
<% end %>