<% @page_title = "会員情報一覧" %>
<h1><%= @page_title %></h1>
<% if @member %>
  <table class = "attr" >
    <thead>
      <tr>
        <th>会員番号</th>
        <th>名前</th>
        <th>権限</th>
        <th>編集</th>
      </tr>
    </thead>
    <tbody>
      <% @member.each do |member| %>
      <tr>
        <td><%= menu_link_to member.id, [:admin, member] %></td>
        <td><%= member.name %></td>
        <td><%= member.role %></td>
        <td></td>
      </tr>
      <% end %>
    </tbody>
  </table>
<% end %>