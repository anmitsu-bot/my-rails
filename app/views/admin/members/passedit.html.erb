<% @page_title = "顧客のパスワードの変更" %>
<h1><%= @page_title %></h1>

<div class="toolbar"><%= link_to "会員情報に戻る", [:admin, @member] %></div>

<%= form_for @member,
    url: p_update_admin_member_path(@member),
    method: :patch do |form| %>
  <%= render "shared/errors", obj: @member %>

  <table class="attr">
    <tr>
      <th><%= form.label :current_password, "現在のパスワード" %></th>
      <td><%= form.password_field :current_password %></td>
    </tr>
    <tr>
      <th><%= form.label :password, "新しいパスワード" %></th>
      <td><%= form.password_field :password %></td>
    </tr>
    <tr>
      <th><%= form.label :password_confirmation,"パスワードの確認" %></th>
      <td><%= form.password_field :password_confirmation %></td>
    </tr>
  </table>

  <div><%= form.submit "変更" %></div>
<% end %>