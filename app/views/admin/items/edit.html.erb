<% @page_title = "商品の編集" %>

<h1><%= @page_title %></h1>

<div class="toolbar"><%= link_to "商品一覧に戻る", :admin_items %></div>

<%= render "shared/errors", obj: @item %>

<%= form_for [:admin, @item] do |form| %>
  <table class = "attr" >
    <tr>
        <th><%= form.label :new_profile_picture, "プロフィール画像" %></th>
        <td>
        </td>
    </tr>
    <tr>
        <th><%= form.label :name, "商品名" %></th>
        <td><%= form.text_field :name  %></td>
    </tr>
    <tr>
        <th><%= form.label :price, "金額" %></th>
        <td><%= form.number_field :price , value: @item.price, min: 0, max: 10000%></td>
    </tr>
    <tr>
        <th><%= form.label :category, "カテゴリ" %></th>
        <td><%= form.number_field :category , value: @item.category, min: 1, max: 3%></td>
    </tr>
    <tr>
        <th><%= form.label :explanation, "説明" %></th>
        <td><%= form.text_area :explanation , rows: 5, cols: 45%></td>
    </tr>
  </table>
  <div><%= form.submit %></div>
<% end %>