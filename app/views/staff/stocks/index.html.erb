<% @page_title = "在庫一覧" %>
<h1><%= @page_title %></h1>

<% if flash[:alert] %>
  <p class="error"><%= flash[:alert] %></p>
<% end %>

<%= form_tag  [:search, :staff, :stocks], method: :get, class: "search" do %>
    <%= text_field_tag "q", params[:q] %>
    <%= radio_button_tag name = "category" ,"1" , false %>
    <%= label_tag "item_category","ピザ" %>
    <%= radio_button_tag name = "category" ,"2" ,  false %>
    <%= label_tag "item_category","ドリンク" %>
    <%= radio_button_tag name = "category" ,"3" ,  false %>
    <%= label_tag "item_category","サイドメニュー" %>
    <%= radio_button_tag name = "category" ,"0" , true %>
    <%= label_tag "item_category","指定なし" %>
    <%= submit_tag "検索" %>
<% end %>

<table class = "attr">
  <thead>
    <tr>
      <th>商品名</th>
      <th>在庫</th>
      <th>在庫追加</th>
    </tr>
  </thead>
  <tbody>
    <% @stocks.each do |stock|%>
      <tr>
        <td><%= stock.from.name %></td>
        <td><%= stock.number %></td>
        <td>
          <%= form_for [:staff, stock]  do |form| %>
            <%= form.number_field  :number %><%= form.submit %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<p><%= link_to "管理TOPへ戻る", :staff_root %></p>