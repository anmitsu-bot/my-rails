<% @page_title = "注文一覧" %>
<h1><%= @page_title %></h1>

<% if @orders.present? %>
  <table class="list">
    <thead>
      <tr>
        <th>注文番号</th>
        <th>値段</th>
        <th>受け取り予定時間</th>
        <th>編集</th>
        <th>作成状況</th>
        <th>受け渡し状況</th>
        <th>作成完了ボタン</th>
        <th>受け渡し完了ボタン</th>
      </tr>
    </thead>
    <tbody>
      <% @orders.each do |order| %>
        <% @all_amount = 0 %>
        <% if order.amount != nil%>
          <% @all_amount = @all_amount+order.amount %>
        <% end %>
        <tr>
          <td style="text-align: right"><%= link_to order.id ,[:staff, order] %></td>
          <td><%= order.amount %></td>
          <td><%= order.reserve_time %></td>
          <td>
            <%= link_to "編集", [:edit, :staff, order] %>
          </td>
          <td><%= order.created %></td>
          <td><%= order.reserved %></td>
          <td><%= button_to "作成完了ボタン", ordercd_staff_order_path(order) , method: :patch %></td>
          <td><%= button_to "受け渡し完了ボタン", orderr_staff_order_path(order) , method: :patch %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>注文がありません。</p>
<% end %>
<h3>合計金額<%= @all_amount %></h3>

<p><%= menu_link_to "管理topへ戻る", :staff_root %></p>